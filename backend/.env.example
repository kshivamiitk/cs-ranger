# Auth
# Strong random secret (>= 32 chars). Generate with ./scripts/generate-secret.sh
# In production the services refuse to start if this is missing or a placeholder.
JWT_SECRET=
JWT_ACCESS_TTL=15m
JWT_REFRESH_TTL=30d

# Supabase
SUPABASE_URL=
SUPABASE_SERVICE_KEY=
SUPABASE_ANON_KEY=

# Razorpay
RAZORPAY_KEY_ID=
RAZORPAY_KEY_SECRET=
RAZORPAY_WEBHOOK_SECRET=
RAZORPAY_ACCOUNT_NUMBER=

# Email
RESEND_API_KEY=
EMAIL_FROM=hello@learnrift.site

# Redis (BullMQ)
REDIS_URL=redis://localhost:6379

# Service ports (overridable)
PORT_GATEWAY=4000
PORT_AUTH=4001
PORT_USER=4002
PORT_COURSE=4003
PORT_ENROLLMENT=4004
PORT_SEARCH=4005
PORT_PAYMENT=4006
PORT_WALLET=4007
PORT_PAYOUT=4008
PORT_NOTIFICATION=4009
PORT_SUPPORT=4010
PORT_ACHIEVEMENT=4011
PORT_ANALYTICS=4012

# Frontend
FRONTEND_URL=http://localhost:3000
