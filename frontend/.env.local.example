# =================================================================
# Frontend (Next.js) env. Copy to frontend/.env.local.
# Anything starting with NEXT_PUBLIC_ is shipped to the browser bundle.
# =================================================================

NEXT_PUBLIC_SITE_NAME=LearnRift
NEXT_PUBLIC_SITE_URL=http://localhost:3000

# API URL.
#   Production: leave blank or set to "/api" — Next.js rewrites /api/* to the
#     local api-gateway (server-side proxy, same-origin, no CORS).
#   Local dev where you hit the gateway directly: http://localhost:4000/api
NEXT_PUBLIC_API_URL=/api

# Optional: override where the Next.js rewrite forwards /api/* on the server side.
# Only set this if api-gateway lives on a different host/port from Next.js.
# Default: http://localhost:4000
# API_GATEWAY_URL=http://localhost:4000

# Supabase (anon key only — never put the service_key here)
NEXT_PUBLIC_SUPABASE_URL=https://YOUR-PROJECT-REF.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=eyJhbGciOiJIUzI1NiI...

# Razorpay checkout (test key id only — never the secret)
NEXT_PUBLIC_RAZORPAY_KEY_ID=rzp_test_YOUR_KEY_ID

# Dev fallback. Set to false to enforce real backend everywhere.
NEXT_PUBLIC_USE_MOCKS=false
