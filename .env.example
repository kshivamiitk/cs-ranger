# =================================================================
# LearnRift — Root .env (template)
#
# Copy to .env on each environment and fill in real values:
#   cp .env.example .env
#
# On the production server this single .env feeds BOTH the backend services
# (sourced by deploy.sh / run.sh) and the frontend build (NEXT_PUBLIC_* are
# inlined into the browser bundle at build time). Anything starting with
# NEXT_PUBLIC_ is shipped to the browser — never put a secret behind that prefix.
#
# Items marked [REQUIRED-PROD] are validated at startup by assertProductionEnv()
# in backend/shared/config.ts: when NODE_ENV=production the services REFUSE to
# start if these are missing or look like placeholders. Items marked [WARN-PROD]
# only log a warning. Generate the JWT secret with: ./scripts/generate-secret.sh
# =================================================================

# ─── Platform identity ────────────────────────────────────────────
NEXT_PUBLIC_SITE_NAME=LearnRift
NEXT_PUBLIC_SITE_URL=https://your-domain.example          # [WARN-PROD] no localhost
FRONTEND_URL=https://your-domain.example                  # [WARN-PROD] CORS origin; no localhost
# Production: "/api" (same-origin, proxied to the gateway). Only use a full URL
# if the gateway lives on a different host. Never localhost in production.
NEXT_PUBLIC_API_URL=/api                                  # [WARN-PROD]

# ─── Supabase ────────────────────────────────────────────────────
# https://app.supabase.com → Project → Settings → API
SUPABASE_URL=https://YOUR-PROJECT-REF.supabase.co         # [REQUIRED-PROD]
SUPABASE_ANON_KEY=
SUPABASE_SERVICE_KEY=                                     # [REQUIRED-PROD] secret — backend only
NEXT_PUBLIC_SUPABASE_URL=https://YOUR-PROJECT-REF.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=

# Supabase Storage buckets — created automatically by the storage-setup script.
SUPABASE_BUCKET_AVATARS=avatars
SUPABASE_BUCKET_THUMBNAILS=course-thumbnails
SUPABASE_BUCKET_ATTACHMENTS=node-attachments
SUPABASE_BUCKET_PDFS=node-pdfs
SUPABASE_BUCKET_STATIC=static-websites
SUPABASE_BUCKET_CERTIFICATES=certificates

# ─── Database (direct) ───────────────────────────────────────────
# Use the pooled URL for the backend services (PgBouncer transaction mode).
DATABASE_URL=
DATABASE_URL_DIRECT=

# ─── JWT (auth-service) ──────────────────────────────────────────
# [REQUIRED-PROD] Must be a strong random secret of >= 32 chars and NOT a
# placeholder. Generate one with: ./scripts/generate-secret.sh
JWT_SECRET=

# ─── Internal gateway↔service trust token ────────────────────────
# [REQUIRED-PROD] The api-gateway stamps this on every proxied request as
# `x-internal-key`; downstream services require it (in production) before
# trusting the x-user-* identity headers the gateway sets from the verified JWT.
# Without it, anyone who can reach a service port directly could forge an
# identity. Use a strong random value (>= 32 chars), e.g. `openssl rand -hex 32`.
INTERNAL_API_SECRET=
JWT_ACCESS_TTL=30m
# How long "remember me" lasts. Refresh tokens rotate on every use and the
# client refreshes proactively, so a returning user stays logged in unless idle
# this long or they clear browser storage.
JWT_REFRESH_TTL_DAYS=180
# RSA public key for distributed verification at api-gateway (optional)
JWT_PUBLIC_KEY=

# ─── Razorpay ────────────────────────────────────────────────────
# Live mode requires KYC of your platform account. Use rzp_test_* only for staging.
RAZORPAY_KEY_ID=                                          # [WARN-PROD] rzp_test_* warns
RAZORPAY_KEY_SECRET=                                      # [WARN-PROD] secret
RAZORPAY_WEBHOOK_SECRET=                                  # [WARN-PROD] secret
RAZORPAY_ACCOUNT_NUMBER=                                  # bank account no. for Razorpay X Payouts
NEXT_PUBLIC_RAZORPAY_KEY_ID=                              # [WARN-PROD] use the LIVE key id in prod

# ─── Email (Resend, or Brevo / SES) ──────────────────────────────
RESEND_API_KEY=                                           # [WARN-PROD] required for real email
EMAIL_FROM="LearnRift <hello@your-domain.example>"
EMAIL_REPLY_TO=support@your-domain.example
# Require email verification before login. TRUE = enforce; anything else (default)
# auto-verifies new accounts. Set to TRUE in production.
EMAIL_VERIFICATION=TRUE                                   # [WARN-PROD]

# Alternative providers (uncomment one set as needed)
# BREVO_API_KEY=
# AWS_SES_REGION=
# AWS_SES_ACCESS_KEY=
# AWS_SES_SECRET_KEY=

# ─── Redis (BullMQ event queue + caching) ────────────────────────
REDIS_URL=
# For Upstash: rediss://default:<token>@<region>.upstash.io:6379

# ─── OAuth (Google) ──────────────────────────────────────────────
# Used by Supabase Auth Google provider; not consumed directly by services.
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=

# ─── Observability (optional) ────────────────────────────────────
SENTRY_DSN=                                               # [WARN-PROD] empty = no error reporting
LOG_LEVEL=info

# ─── Backend service ports (overridable) ─────────────────────────
PORT_GATEWAY=4000
PORT_AUTH=4001
PORT_USER=4002
PORT_COURSE=4003
PORT_ENROLLMENT=4004
PORT_SEARCH=4005
PORT_PAYMENT=4006
PORT_WALLET=4007
PORT_PAYOUT=4008
PORT_NOTIFICATION=4009
PORT_SUPPORT=4010
PORT_ACHIEVEMENT=4011
PORT_ANALYTICS=4012

# ─── Platform settings (initial; can also be set via /admin/settings) ──
PLATFORM_COMMISSION_RATE=0.15
PLATFORM_MIN_PAYOUT_INR=500
PLATFORM_REFUND_WINDOW_DAYS=7
PLATFORM_TDS_RATE=0.10
PLATFORM_TDS_THRESHOLD_INR=50000

# ─── Creator storage quota ───────────────────────────────────────
CREATOR_STORAGE_FREE_MB=2
CREATOR_STORAGE_PRICE_PER_MB_INR=5
CREATOR_STORAGE_DURATION_DAYS=30

# ─── Runtime ─────────────────────────────────────────────────────
# When true, frontend falls back to mock data if the API is unreachable.
NEXT_PUBLIC_USE_MOCKS=false
# MUST be "production" on the production server. Drives fail-fast env validation.
NODE_ENV=production
